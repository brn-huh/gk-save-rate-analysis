# 이 파일을 .env.local 로 복사해서 값을 채우세요. (.env.local 은 커밋되지 않음)
#   cp .env.local.example .env.local

# 넥슨 Open API 키 (필수, 수집 시에만 사용 — 배포물엔 안 들어감)
NEXON_API_KEY=여기에_발급키

# 선택: 수집 속도 (기본 5, 넥슨 한도 분당1000 → 안전 최대 ~15)
# 실측(2026-07-11): 응답 지연 중앙값 5.3초라 15 예산의 76%만 사용 → 레이트는 병목 아님.
GKSAVE_RATE=15
# 선택: 동시 요청 수 (기본 18)
# 실측: 동시성 12/18/24 에서 429 전부 0회. 처리량 8.1/8.9/9.4 매치/초.
# 24는 예산 턱밑이라 18로 여유를 둔다. 더 올리려면 로그의 '429 N회'를 보며 조절.
GKSAVE_CONCURRENCY=18
# 선택: 데이터 저장 위치 (기본 data/)
GKSAVE_DATA_DIR=data
